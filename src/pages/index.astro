---
import BaseLayout from '../layouts/BaseLayout.astro'

const stacks = [
  { name: 'go', icon: '🟢', title: 'Go', desc: '并发与后端利器', path: '/go' },
  { name: 'nodejs', icon: '🟩', title: 'Node.js', desc: '全栈 JavaScript 运行时', path: '/nodejs' },
  { name: 'python', icon: '🔵', title: 'Python', desc: '通用编程与数据科学', path: '/python' },
  { name: 'web-前端', icon: '🟡', title: 'Web 前端', desc: '现代 Web 前端技术', path: '/web-前端' }
]
---

<BaseLayout title="首页">
  <div class="home-hero">
    <h1>XQZ 技术知识库</h1>
    <p>系统化的技术学习笔记 — Go / Node.js / Python / Web 前端</p>
  </div>

  <div class="home-features">
    {stacks.map(s => (
      <a href={s.path} class="feature-card">
        <div class="icon">{s.icon}</div>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
      </a>
    ))}
  </div>
</BaseLayout>
